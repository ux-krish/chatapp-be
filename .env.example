# =========================================================================
# Backend Environment Configuration - Example
# Copy this file to '.env' and fill in your actual values.
# =========================================================================

PORT=5001
NODE_ENV=development

# JWT Secrets for Authentication
JWT_ACCESS_SECRET=your_super_secure_access_token_secret_key_change_me_2026
JWT_REFRESH_SECRET=your_super_secure_refresh_token_secret_key_change_me_2026

# =========================================================================
# Firebase Service Account Credentials (For server-side Firestore/Storage)
# =========================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com

# For the private key, replace literal newlines with \n when placing inside a single-line string
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC7...\n-----END PRIVATE KEY-----\n"

# =========================================================================
# SMTP Email Settings (For real email OTP verification)
# =========================================================================
# For Gmail, set:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587 (TLS) or 465 (SSL)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-16-character-gmail-app-password
# EMAIL_FROM="Secure Chat <your-email@gmail.com>"
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
